# Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Gmail SMTP (for sending newsletter to yourself)
# 1. Enable 2FA on your Google account
# 2. Go to https://myaccount.google.com/apppasswords
# 3. Create an App Password for "Mail"
GMAIL_USER=your_gmail@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Where to send the newsletter (defaults to GMAIL_USER if not set)
NEWSLETTER_RECIPIENT_EMAIL=your_gmail@gmail.com

# Reddit (optional - for scraping immigration subreddits)
REDDIT_CLIENT_ID=your_reddit_client_id_here
REDDIT_CLIENT_SECRET=your_reddit_client_secret_here
REDDIT_USER_AGENT=immigration-newsletter-bot/1.0

# WordPress (for SEO farm publishing)
# 1. In WP Admin: Users → Profile → Application Passwords → Add New
# 2. Copy the generated password (spaces don't matter)
WP_URL=https://yourdomain.com
WP_USERNAME=your_wp_username
WP_APP_PASSWORD=xxxx xxxx xxxx xxxx xxxx xxxx
